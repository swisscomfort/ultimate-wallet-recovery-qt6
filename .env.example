# Ultimate Wallet Recovery Tool - Environment Configuration
# Copy this file to .env and fill in your actual API keys

# Blockchain Explorer API Keys
ETHERSCAN_API_KEY=your_etherscan_api_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
ARBISCAN_API_KEY=your_arbiscan_api_key_here
OPTIMISM_API_KEY=your_optimism_api_key_here
SNOWTRACE_API_KEY=your_snowtrace_api_key_here
FTMSCAN_API_KEY=your_ftmscan_api_key_here

# Security Settings
ENCRYPTION_PASSWORD=your_secure_encryption_password
DATABASE_ENCRYPTION_KEY=your_database_encryption_key

# Performance Settings
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=15
RATE_LIMIT_DELAY=1.2

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/wallet_recovery.log

# Backup Settings
BACKUP_ENABLED=true
BACKUP_LOCATION=./backups/
BACKUP_ENCRYPTION=true
